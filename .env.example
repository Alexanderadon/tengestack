# Регистрация приложения: https://dev.hh.ru/admin (тип — «API для приложений»).
# Client credentials → app token получается автоматически скриптом data:fetch.
HH_CLIENT_ID=
HH_CLIENT_SECRET=
# Либо готовый app-токен напрямую (тогда client_id/secret не нужны):
HH_APP_TOKEN=
# Контакт в User-Agent (требование HH API):
HH_CONTACT_EMAIL=adamdimert@gmail.com
